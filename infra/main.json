{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "12842258447395660085"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "allowedValues": [
        "dev",
        "prod"
      ],
      "metadata": {
        "description": "Environment name — drives SKU selection and resource naming"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "defaultValue": "sqladmin",
      "metadata": {
        "description": "SQL Server administrator login"
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "SQL Server administrator password"
      }
    }
  },
  "variables": {
    "suffix": "[take(uniqueString(subscription().id, resourceGroup().name), 8)]",
    "prefix": "[format('driveease-{0}', parameters('environmentName'))]"
  },
  "resources": {
    "sql": {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "deploy-sql",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "serverName": {
            "value": "[format('{0}-sql-{1}', variables('prefix'), variables('suffix'))]"
          },
          "databaseName": {
            "value": "driveease"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "adminLogin": {
            "value": "[parameters('sqlAdminLogin')]"
          },
          "adminPassword": {
            "value": "[parameters('sqlAdminPassword')]"
          },
          "skuName": "[if(equals(parameters('environmentName'), 'prod'), createObject('value', 'S2'), createObject('value', 'Basic'))]",
          "skuTier": "[if(equals(parameters('environmentName'), 'prod'), createObject('value', 'Standard'), createObject('value', 'Basic'))]",
          "skuCapacity": "[if(equals(parameters('environmentName'), 'prod'), createObject('value', 50), createObject('value', 5))]"
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "languageVersion": "2.0",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "8032630416135637386"
            }
          },
          "parameters": {
            "serverName": {
              "type": "string",
              "metadata": {
                "description": "SQL Server resource name — must be globally unique"
              }
            },
            "databaseName": {
              "type": "string",
              "metadata": {
                "description": "Database name"
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            },
            "adminLogin": {
              "type": "string",
              "metadata": {
                "description": "SQL administrator login"
              }
            },
            "adminPassword": {
              "type": "securestring",
              "metadata": {
                "description": "SQL administrator password (min 8 chars, upper + lower + digit + special)"
              }
            },
            "skuName": {
              "type": "string",
              "defaultValue": "Basic",
              "metadata": {
                "description": "Database SKU name — Basic | S1 | S2 | P1 | …"
              }
            },
            "skuTier": {
              "type": "string",
              "defaultValue": "Basic",
              "metadata": {
                "description": "Database SKU service tier — Basic | Standard | Premium"
              }
            },
            "skuCapacity": {
              "type": "int",
              "defaultValue": 5,
              "metadata": {
                "description": "DTU capacity matching the chosen tier"
              }
            }
          },
          "resources": {
            "sqlServer": {
              "type": "Microsoft.Sql/servers",
              "apiVersion": "2023-08-01-preview",
              "name": "[parameters('serverName')]",
              "location": "[parameters('location')]",
              "properties": {
                "administratorLogin": "[parameters('adminLogin')]",
                "administratorLoginPassword": "[parameters('adminPassword')]",
                "minimalTlsVersion": "1.2",
                "publicNetworkAccess": "Enabled"
              }
            },
            "sqlDatabase": {
              "type": "Microsoft.Sql/servers/databases",
              "apiVersion": "2023-08-01-preview",
              "name": "[format('{0}/{1}', parameters('serverName'), parameters('databaseName'))]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "[parameters('skuName')]",
                "tier": "[parameters('skuTier')]",
                "capacity": "[parameters('skuCapacity')]"
              },
              "properties": {
                "collation": "SQL_Latin1_General_CP1_CI_AS",
                "maxSizeBytes": "[if(equals(parameters('skuTier'), 'Basic'), json('2147483648'), json('21474836480'))]",
                "requestedBackupStorageRedundancy": "Local"
              },
              "dependsOn": [
                "sqlServer"
              ]
            },
            "allowAzureServices": {
              "type": "Microsoft.Sql/servers/firewallRules",
              "apiVersion": "2023-08-01-preview",
              "name": "[format('{0}/{1}', parameters('serverName'), 'AllowAzureServices')]",
              "properties": {
                "startIpAddress": "0.0.0.0",
                "endIpAddress": "0.0.0.0"
              },
              "dependsOn": [
                "sqlServer"
              ]
            }
          },
          "outputs": {
            "connectionString": {
              "type": "securestring",
              "value": "[format('Server=tcp:{0},1433;Database={1};User Id={2};Password={3};Encrypt=true;TrustServerCertificate=false;Connection Timeout=30;', reference('sqlServer').fullyQualifiedDomainName, parameters('databaseName'), parameters('adminLogin'), parameters('adminPassword'))]"
            },
            "serverFqdn": {
              "type": "string",
              "value": "[reference('sqlServer').fullyQualifiedDomainName]"
            },
            "serverId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Sql/servers', parameters('serverName'))]"
            }
          }
        }
      }
    },
    "serviceBus": {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "deploy-servicebus",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "namespaceName": {
            "value": "[format('{0}-sb-{1}', variables('prefix'), variables('suffix'))]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "skuName": {
            "value": "Standard"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "languageVersion": "2.0",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "4998597649242188803"
            }
          },
          "parameters": {
            "namespaceName": {
              "type": "string",
              "metadata": {
                "description": "Service Bus namespace name — must be globally unique"
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            },
            "skuName": {
              "type": "string",
              "defaultValue": "Standard",
              "allowedValues": [
                "Basic",
                "Standard",
                "Premium"
              ],
              "metadata": {
                "description": "Service Bus SKU — Basic (queues only) | Standard | Premium"
              }
            }
          },
          "resources": {
            "namespace": {
              "type": "Microsoft.ServiceBus/namespaces",
              "apiVersion": "2022-10-01-preview",
              "name": "[parameters('namespaceName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "[parameters('skuName')]",
                "tier": "[parameters('skuName')]"
              },
              "properties": {
                "minimumTlsVersion": "1.2",
                "publicNetworkAccess": "Enabled",
                "disableLocalAuth": false
              }
            },
            "enrollmentEventsTopic": {
              "condition": "[not(equals(parameters('skuName'), 'Basic'))]",
              "type": "Microsoft.ServiceBus/namespaces/topics",
              "apiVersion": "2022-10-01-preview",
              "name": "[format('{0}/{1}', parameters('namespaceName'), 'enrollment-events')]",
              "properties": {
                "defaultMessageTimeToLive": "P7D",
                "enableBatchedOperations": true,
                "requiresDuplicateDetection": false
              },
              "dependsOn": [
                "namespace"
              ]
            },
            "lessonEventsTopic": {
              "condition": "[not(equals(parameters('skuName'), 'Basic'))]",
              "type": "Microsoft.ServiceBus/namespaces/topics",
              "apiVersion": "2022-10-01-preview",
              "name": "[format('{0}/{1}', parameters('namespaceName'), 'lesson-events')]",
              "properties": {
                "defaultMessageTimeToLive": "P7D",
                "enableBatchedOperations": true,
                "requiresDuplicateDetection": false
              },
              "dependsOn": [
                "namespace"
              ]
            },
            "enrollmentConfirmedSub": {
              "condition": "[not(equals(parameters('skuName'), 'Basic'))]",
              "type": "Microsoft.ServiceBus/namespaces/topics/subscriptions",
              "apiVersion": "2022-10-01-preview",
              "name": "[format('{0}/{1}/{2}', parameters('namespaceName'), 'enrollment-events', 'enrollment-confirmed')]",
              "properties": {
                "lockDuration": "PT1M",
                "defaultMessageTimeToLive": "P7D",
                "deadLetteringOnMessageExpiration": true,
                "maxDeliveryCount": 5
              },
              "dependsOn": [
                "enrollmentEventsTopic"
              ]
            },
            "enrollmentAlertSub": {
              "condition": "[not(equals(parameters('skuName'), 'Basic'))]",
              "type": "Microsoft.ServiceBus/namespaces/topics/subscriptions",
              "apiVersion": "2022-10-01-preview",
              "name": "[format('{0}/{1}/{2}', parameters('namespaceName'), 'enrollment-events', 'enrollment-alert')]",
              "properties": {
                "lockDuration": "PT1M",
                "defaultMessageTimeToLive": "P7D",
                "deadLetteringOnMessageExpiration": true,
                "maxDeliveryCount": 5
              },
              "dependsOn": [
                "enrollmentEventsTopic"
              ]
            },
            "lessonReminderSub": {
              "condition": "[not(equals(parameters('skuName'), 'Basic'))]",
              "type": "Microsoft.ServiceBus/namespaces/topics/subscriptions",
              "apiVersion": "2022-10-01-preview",
              "name": "[format('{0}/{1}/{2}', parameters('namespaceName'), 'lesson-events', 'lesson-reminder')]",
              "properties": {
                "lockDuration": "PT1M",
                "defaultMessageTimeToLive": "P7D",
                "deadLetteringOnMessageExpiration": true,
                "maxDeliveryCount": 5
              },
              "dependsOn": [
                "lessonEventsTopic"
              ]
            },
            "lessonCompletedSub": {
              "condition": "[not(equals(parameters('skuName'), 'Basic'))]",
              "type": "Microsoft.ServiceBus/namespaces/topics/subscriptions",
              "apiVersion": "2022-10-01-preview",
              "name": "[format('{0}/{1}/{2}', parameters('namespaceName'), 'lesson-events', 'lesson-completed')]",
              "properties": {
                "lockDuration": "PT1M",
                "defaultMessageTimeToLive": "P7D",
                "deadLetteringOnMessageExpiration": true,
                "maxDeliveryCount": 5
              },
              "dependsOn": [
                "lessonEventsTopic"
              ]
            },
            "appAuthRule": {
              "type": "Microsoft.ServiceBus/namespaces/AuthorizationRules",
              "apiVersion": "2022-10-01-preview",
              "name": "[format('{0}/{1}', parameters('namespaceName'), 'DriveEaseApp')]",
              "properties": {
                "rights": [
                  "Send",
                  "Listen"
                ]
              },
              "dependsOn": [
                "namespace"
              ]
            }
          },
          "outputs": {
            "primaryConnectionString": {
              "type": "securestring",
              "value": "[listKeys('appAuthRule', '2022-10-01-preview').primaryConnectionString]"
            },
            "namespaceName": {
              "type": "string",
              "value": "[parameters('namespaceName')]"
            },
            "namespaceId": {
              "type": "string",
              "value": "[resourceId('Microsoft.ServiceBus/namespaces', parameters('namespaceName'))]"
            }
          }
        }
      }
    },
    "api": {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "deploy-api",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "appName": {
            "value": "[format('{0}-api-{1}', variables('prefix'), variables('suffix'))]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "planSku": "[if(equals(parameters('environmentName'), 'prod'), createObject('value', 'P2v3'), createObject('value', 'B1'))]",
          "sqlConnectionString": {
            "value": "[listOutputsWithSecureValues('sql', '2025-04-01').connectionString]"
          },
          "serviceBusConnectionString": {
            "value": "[listOutputsWithSecureValues('serviceBus', '2025-04-01').primaryConnectionString]"
          },
          "environmentName": {
            "value": "[parameters('environmentName')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "12027715304534577023"
            }
          },
          "parameters": {
            "appName": {
              "type": "string",
              "metadata": {
                "description": "App Service name — must be globally unique"
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            },
            "planSku": {
              "type": "string",
              "defaultValue": "B1",
              "metadata": {
                "description": "App Service Plan SKU — B1 (dev) | P2v3 (prod)"
              }
            },
            "sqlConnectionString": {
              "type": "securestring",
              "metadata": {
                "description": "SQL Server connection string (injected into connection string slot)"
              }
            },
            "serviceBusConnectionString": {
              "type": "securestring",
              "metadata": {
                "description": "Service Bus primary connection string"
              }
            },
            "environmentName": {
              "type": "string",
              "metadata": {
                "description": "Environment name — sets ASPNETCORE_ENVIRONMENT app setting"
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Web/serverfarms",
              "apiVersion": "2023-12-01",
              "name": "[format('{0}-plan', parameters('appName'))]",
              "location": "[parameters('location')]",
              "kind": "linux",
              "sku": {
                "name": "[parameters('planSku')]"
              },
              "properties": {
                "reserved": true
              }
            },
            {
              "type": "Microsoft.Web/sites",
              "apiVersion": "2023-12-01",
              "name": "[parameters('appName')]",
              "location": "[parameters('location')]",
              "kind": "app,linux",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('appName')))]",
                "httpsOnly": true,
                "siteConfig": {
                  "linuxFxVersion": "DOTNETCORE|10.0",
                  "minTlsVersion": "1.2",
                  "ftpsState": "Disabled",
                  "http20Enabled": true,
                  "alwaysOn": "[not(equals(parameters('planSku'), 'F1'))]",
                  "appSettings": [
                    {
                      "name": "ASPNETCORE_ENVIRONMENT",
                      "value": "[if(equals(parameters('environmentName'), 'prod'), 'Production', 'Development')]"
                    },
                    {
                      "name": "ServiceBus__ConnectionString",
                      "value": "[parameters('serviceBusConnectionString')]"
                    }
                  ],
                  "connectionStrings": [
                    {
                      "name": "DefaultConnection",
                      "connectionString": "[parameters('sqlConnectionString')]",
                      "type": "SQLAzure"
                    }
                  ]
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('appName')))]"
              ]
            }
          ],
          "outputs": {
            "appUrl": {
              "type": "string",
              "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('appName')), '2023-12-01').defaultHostName)]"
            },
            "appName": {
              "type": "string",
              "value": "[parameters('appName')]"
            },
            "principalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Web/sites', parameters('appName')), '2023-12-01', 'full').identity.principalId]"
            }
          }
        }
      },
      "dependsOn": [
        "serviceBus",
        "sql"
      ]
    }
  },
  "outputs": {
    "apiUrl": {
      "type": "string",
      "value": "[reference('api').outputs.appUrl.value]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "value": "[reference('sql').outputs.serverFqdn.value]"
    },
    "serviceBusNamespace": {
      "type": "string",
      "value": "[reference('serviceBus').outputs.namespaceName.value]"
    }
  }
}